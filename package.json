{
  "name": "mini-pomodoro",
  "version": "1.0.1",
  "main": "main.js",
  "description": "A minimal Pomodoro timer desktop widget",
  "author": "skymen",
  "license": "ISC",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "release": "bash release.sh",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.skymen.mini-pomodoro",
    "productName": "Mini Pomodoro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "keywords": [],
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.0.12",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}
